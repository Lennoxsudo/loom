{
  "name": "loom",
  "private": true,
  "version": "0.1.3",
  "description": "AI-native desktop code editor and local development workbench built with Tauri 2, React 19 and Rust.",
  "license": "Apache-2.0",
  "author": "Lennoxsudo",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lennoxsudo/loom.git"
  },
  "homepage": "https://github.com/Lennoxsudo/loom#readme",
  "bugs": {
    "url": "https://github.com/Lennoxsudo/loom/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "fetch:cbm": "node scripts/fetch-cbm-sidecar.mjs",
    "check:dead-files": "node scripts/dead-file-check.cjs",
    "tauri:build": "npm run tauri -- build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "diff": "^8.0.3",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "react-virtuoso": "^4.18.1",
    "remark-gfm": "^4.0.1",
    "vscode-material-icons": "^0.1.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "fast-check": "^4.5.3",
    "globals": "^17.3.0",
    "jsdom": "^27.4.0",
    "monaco-editor-nls": "^3.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.0.4",
    "vite-plugin-monaco-editor-nls": "^3.0.1",
    "vitest": "^4.0.18"
  }
}
